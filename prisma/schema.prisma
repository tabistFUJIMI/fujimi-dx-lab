generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["fujimi_dx_lab_hp"]
}

model Contact {
  id        String   @id @default(cuid())
  type      String   // お問い合わせ種別
  name      String
  email     String
  company   String?  // 会社名/店舗名
  message   String
  status    String   @default("new") // new | replied | closed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contacts")
  @@schema("fujimi_dx_lab_hp")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  excerpt     String?   // 未設定時は本文先頭100文字
  category    String    @default("info") // info | event | important | campaign
  eventDate   DateTime? @map("event_date")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([eventDate])
  @@map("announcements")
  @@schema("fujimi_dx_lab_hp")
}

model Column {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String    // Markdown or HTML
  excerpt     String?   // 未設定時は本文先頭120文字
  category    String    @default("basics") // basics | ai-strategy | practice | case-study
  tags        String[]  @default([])
  ogImage     String?   @map("og_image")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([slug])
  @@map("columns")
  @@schema("fujimi_dx_lab_hp")
}

model GaToken {
  id           String   @id @default("ga_oauth")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ga_tokens")
  @@schema("fujimi_dx_lab_hp")
}

model AnalyticsReport {
  id            String   @id @default(cuid())
  period        Int
  analyticsData String   @map("analytics_data")
  analysis      String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("analytics_reports")
  @@schema("fujimi_dx_lab_hp")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  feature      String   // "geo-checker" | "analytics" など機能名
  model        String   // "claude-haiku-4-5-20251001" etc
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Float    @map("cost_usd") // 計算済みUSドルコスト
  targetUrl    String?  @map("target_url") // チェッカーの場合は対象URL
  durationMs   Int?     @map("duration_ms") // API応答時間
  success      Boolean  @default(true)
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage_logs")
  @@schema("fujimi_dx_lab_hp")
}

model BotAccessLog {
  id        String   @id @default(cuid())
  botName   String   @map("bot_name")
  botTier   String   @map("bot_tier")
  url       String
  method    String   @default("GET")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([botName])
  @@index([botTier])
  @@index([url])
  @@index([createdAt])
  @@map("bot_access_logs")
  @@schema("fujimi_dx_lab_hp")
}

model BotDailyStats {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  botName     String   @map("bot_name")
  botTier     String   @map("bot_tier")
  url         String
  accessCount Int      @default(0) @map("access_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([date, botName, url])
  @@index([date])
  @@index([botName])
  @@index([botTier])
  @@map("bot_daily_stats")
  @@schema("fujimi_dx_lab_hp")
}
