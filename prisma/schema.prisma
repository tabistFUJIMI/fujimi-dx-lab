generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["fujimi_dx_lab_hp"]
}

model Contact {
  id        String   @id @default(cuid())
  type      String   // お問い合わせ種別
  name      String
  email     String
  company   String?  // 会社名/店舗名
  message   String
  status    String   @default("new") // new | replied | closed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contacts")
  @@schema("fujimi_dx_lab_hp")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  excerpt     String?   // 未設定時は本文先頭100文字
  category    String    @default("info") // info | event | important | campaign
  eventDate   DateTime? @map("event_date")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([eventDate])
  @@map("announcements")
  @@schema("fujimi_dx_lab_hp")
}

model Column {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String    // Markdown or HTML
  excerpt     String?   // 未設定時は本文先頭120文字
  category    String    @default("basics") // basics | ai-strategy | practice | case-study
  tags        String[]  @default([])
  ogImage     String?   @map("og_image")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([slug])
  @@map("columns")
  @@schema("fujimi_dx_lab_hp")
}

model GaToken {
  id           String   @id @default("ga_oauth")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ga_tokens")
  @@schema("fujimi_dx_lab_hp")
}
